{
    "name": "aureuserp/progress-bar",
    "description": "A Filament v5 progress-bar table column & infolist entry with sizes, shapes, stripes, gradients, thresholds, and ARIA-compliant output.",
    "keywords": [
        "aureuserp",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "progress-bar"
    ],
    "homepage": "https://github.com/aureuserp/progress-bar",
    "license": "MIT",
    "authors": [
        {
            "name": "Webkul",
            "email": "support@webkul.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "filament/infolists": "^5.0",
        "filament/tables": "^5.0",
        "spatie/laravel-package-tools": "^1.15"
    },
    "autoload": {
        "psr-4": {
            "Webkul\\ProgressBar\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webkul\\ProgressBar\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webkul\\ProgressBar\\ProgressBarServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
